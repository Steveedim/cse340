<%- include('partials/header') %>

<main>

    <h1><%= title %></h1>

    <h2>Project Categories</h2>

    <div>

        <% categories.forEach(category => { %>

            <a href="/category/<%= category.category_id %>">

                <span>
                    <%= category.name %>
                </span>

            </a>

        <% }) %>

    </div>

</main>

<%- include('partials/footer') %>