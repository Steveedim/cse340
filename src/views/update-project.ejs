<%- include('partials/header') %>

<main>

<h1>Edit Service Project</h1>

<form action="/edit-project/<%= project.project_id %>" method="POST">

    <label for="title">Title</label>
    <input
        type="text"
        id="title"
        name="title"
        value="<%= project.title %>"
        required
    >

    <label for="description">Description</label>
    <textarea
        id="description"
        name="description"
        required
    ><%= project.description %></textarea>

    <label for="location">Location</label>
    <input
        type="text"
        id="location"
        name="location"
        value="<%= project.location %>"
        required
    >

    <label for="project_date">Date</label>
    <input
        type="date"
        id="project_date"
        name="project_date"
        value="<%= project.project_date.toISOString().split('T')[0] %>"
        required
    >

    <label for="organization_id">Organization</label>
    <select
        id="organization_id"
        name="organization_id"
        required
    >
        <% organizations.forEach(org => { %>

            <option
                value="<%= org.organization_id %>"
                <%= org.organization_id === project.organization_id ? 'selected' : '' %>
            >
                <%= org.name %>
            </option>

        <% }) %>
    </select>

    <button type="submit">
        Update Project
    </button>

</form>

</main>

<%- include('partials/footer') %>